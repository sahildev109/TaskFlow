# Example environment variables for TaskFlow backend
# Copy this file to `.env` and fill in real secrets before running.

# App
APP_NAME=TaskFlow API
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Database (Neon PostgreSQL)
# Use the asyncpg scheme for async SQLAlchemy: postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=postgresql://<DB_USER>:<DB_PASS>@<HOST>/<DB_NAME>?ssl=require

# JWT
SECRET_KEY=replace-with-a-32-char-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (local or Upstash)
REDIS_URL=redis://localhost:6379

# CORS — comma-separated allowed origins for the frontend
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Notes:
# - Never commit your real `.env` to version control. Keep secrets out of the repo.
# - For Neon, use the connection string provided by the Neon dashboard and replace the
#   placeholder above. Example:
#   postgresql://db_user:db_pass@ep-xxxxx.neon.tech/neondb?sslmode=require
