# Example frontend env for TaskFlow (Next.js)
# Copy this file to `.env.local` in the frontend folder and adjust values.

# Base API URL used by the frontend to reach the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional: add other NEXT_PUBLIC_ variables here (analytics, feature flags, etc.)

# Notes:
# - `NEXT_PUBLIC_*` variables are exposed to client-side code; do not place secrets here.
